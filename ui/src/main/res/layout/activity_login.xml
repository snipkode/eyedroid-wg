<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
<data/>

<FrameLayout
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/ed_bg">

    <!-- Grid background drawn by custom view -->
    <com.eyedroid.vpn.ui.login.TechParticleView
        android:id="@+id/particleView"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- Decorative corner brackets -->
    <View android:layout_width="40dp" android:layout_height="40dp"
        android:layout_gravity="top|start" android:layout_margin="20dp"
        android:background="@drawable/corner_tl" />
    <View android:layout_width="40dp" android:layout_height="40dp"
        android:layout_gravity="top|end" android:layout_margin="20dp"
        android:background="@drawable/corner_tr" />
    <View android:layout_width="40dp" android:layout_height="40dp"
        android:layout_gravity="bottom|start" android:layout_margin="20dp"
        android:background="@drawable/corner_bl" />
    <View android:layout_width="40dp" android:layout_height="40dp"
        android:layout_gravity="bottom|end" android:layout_margin="20dp"
        android:background="@drawable/corner_br" />

    <!-- Main content -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingHorizontal="28dp"
            android:paddingTop="72dp"
            android:paddingBottom="40dp"
            android:minHeight="600dp">

            <!-- Logo -->
            <ImageView
                android:layout_width="88dp"
                android:layout_height="88dp"
                android:src="@mipmap/ic_launcher"
                android:contentDescription="@string/app_name"
                android:layout_marginBottom="16dp" />

            <!-- Title: Access Interface -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Access Interface"
                android:textColor="@color/ed_text_primary"
                android:textSize="26sp"
                android:textStyle="bold"
                android:letterSpacing="-0.02"
                android:layout_marginBottom="6dp" />

            <!-- Subtitle: Neural Link Secured -->
            <TextView
                android:id="@+id/tvTenantBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/tenant_badge_default"
                android:textColor="#99BAC9CC"
                android:textSize="10sp"
                android:textAllCaps="true"
                android:letterSpacing="0.15"
                android:layout_marginBottom="36dp" />

            <!-- Glass panel card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_glass_panel"
                android:padding="24dp">

                <!-- Droid ID label -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="DROID ID"
                    android:textColor="#CC00E5FF"
                    android:textSize="10sp"
                    android:textAllCaps="true"
                    android:letterSpacing="0.1"
                    android:layout_marginBottom="6dp"
                    android:layout_marginStart="2dp" />

                <!-- Username input -->
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/tilUsername"
                    style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="20dp"
                    app:startIconDrawable="@drawable/ic_fingerprint"
                    app:startIconTint="@color/ed_text_secondary"
                    app:boxStrokeColor="@color/ed_accent"
                    app:boxStrokeWidth="1dp"
                    app:boxBackgroundColor="#010F1F"
                    app:hintEnabled="false">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etUsername"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="ED-0000-X"
                        android:inputType="text"
                        android:imeOptions="actionNext"
                        android:singleLine="true"
                        android:textColor="@color/ed_text_primary"
                        android:textColorHint="#4DBAC9CC"
                        android:fontFamily="monospace"
                        android:textSize="13sp" />
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Access Key label -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ACCESS KEY"
                    android:textColor="#CC00E5FF"
                    android:textSize="10sp"
                    android:textAllCaps="true"
                    android:letterSpacing="0.1"
                    android:layout_marginBottom="6dp"
                    android:layout_marginStart="2dp" />

                <!-- Password input -->
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/tilPassword"
                    style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="24dp"
                    app:startIconDrawable="@drawable/ic_key"
                    app:startIconTint="@color/ed_text_secondary"
                    app:endIconMode="password_toggle"
                    app:boxStrokeColor="@color/ed_accent"
                    app:boxStrokeWidth="1dp"
                    app:boxBackgroundColor="#010F1F"
                    app:hintEnabled="false">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etPassword"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="••••••••"
                        android:inputType="textPassword"
                        android:imeOptions="actionDone"
                        android:singleLine="true"
                        android:textColor="@color/ed_text_primary"
                        android:textColorHint="#4DBAC9CC"
                        android:fontFamily="monospace"
                        android:textSize="13sp" />
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Connect button -->
                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="52dp">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnLogin"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:text="CONNECT"
                        android:textColor="@color/ed_accent"
                        android:textStyle="bold"
                        android:textSize="12sp"
                        android:letterSpacing="0.2"
                        app:backgroundTint="#00626E"
                        app:strokeColor="@color/ed_accent"
                        app:strokeWidth="1dp"
                        app:cornerRadius="8dp" />

                    <ProgressBar
                        android:id="@+id/progressBar"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_gravity="center"
                        android:visibility="gone"
                        android:indeterminateTint="@color/ed_accent" />
                </FrameLayout>

            </LinearLayout>

            <!-- Version info -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="28dp"
                android:text="EYEDROID CORE v4.0.0-STABLE"
                android:textColor="#4DBAC9CC"
                android:textSize="9sp"
                android:letterSpacing="0.25"
                android:textAllCaps="true" />

        </LinearLayout>
    </ScrollView>

</FrameLayout>
</layout>
